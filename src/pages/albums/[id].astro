---
import { getCollection, getEntry } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import InnerPage from "../../components/InnerPage.astro";
import { Masonry } from "astro-masonry";

export async function getStaticPaths() {
    const albums = await getCollection("albums");
    return albums.map((album) => ({
        params: { id: album.id },
        props: { album },
    }));
}

const { album } = Astro.props;
const { title, description, images } = album.data;
---

<BaseLayout title={title}>

    <InnerPage title={title} description={description}>

    <main class="album-page">

        {
            images && images.length > 0 ? (
                <div class="image-grid-wrap">
                    <Masonry breakpointCols={{ default: 3, 768: 2, 480: 1 }}
                             sortByHeight={true}>
                        {images.map((img) => (
                            <figure>
                                <Image
                                    src={img.file}
                                    alt={img.title ?? ""}
                                    width={img.file.width}
                                    height={img.file.height}
                                />
                                {img.title && (
                                    <figcaption>
                                        <strong>{img.title}.</strong>
                                        {img.description && (
                                            <span>{img.description}</span>
                                        )}
                                    </figcaption>
                                )}
                            </figure>
                        ))}
                    </Masonry>
                </div>
            ) : (
                <p class="empty">No images yet.</p>
            )
        }
    </main>

    </InnerPage>
</BaseLayout>

<script>import "../../scripts/lightbox.ts";</script>


<style lang="scss">
    @use "../../styles/tokens" as *;

    .album-page {
        padding: $gap;
        /* max-width: 1200px; */
        /* margin: 0 auto; */
    }

    .image-grid-wrap {
        max-width: 1200px;
        margin: 0 auto;
    }

    :global(.astro-masonry-grid) {
        display: flex;
        width: auto;
        margin-left: -$gap;
    }

    :global(.astro-masonry-grid_column) {
        padding-left: $gap;
        background-clip: padding-box;
    }

    figure {
        margin: 0 0 $gap 0;  // vertical gap between stacked images
        img {
            width: 100%;
            height: auto;
            display: block;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.5);
        }
        figcaption {
            padding: 0.5rem 0;
            font-family: $font-body;
            font-size: 0.8rem;
            color: $color-muted;
            strong {
                color: $color-text;
            }
        }
    }
    .empty {
        color: $color-muted;
        font-family: $font-body;
    }
</style>
