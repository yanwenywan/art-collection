---
import { getCollection, getEntry } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import InnerPage from "../../components/InnerPage.astro";

export async function getStaticPaths() {
    const albums = await getCollection("albums");
    return albums.map((album) => ({
        params: { id: album.id },
        props: { album },
    }));
}

const { album } = Astro.props;
const { title, description, images } = album.data;
---

<BaseLayout title={title}>

    <InnerPage title={title} description={description}>

    <div class="lightbox-overlay" id="lightbox">
        <img id="lightbox-img" src="" alt="" />
        <figcaption id="lightbox-caption"></figcaption>
    </div>

    <main class="album-page">

        {
            images && images.length > 0 ? (
                <div class="image-grid">
                    {images.map((img) => (
                        <figure>
                            <Image
                                src={img.file}
                                alt={img.title ?? ""}
                                width={img.file.width}
                                height={img.file.height}
                            />
                            {img.title && (
                                <figcaption>
                                    <strong>{img.title}.</strong>
                                    {img.description && (
                                        <span>{img.description}</span>
                                    )}
                                </figcaption>
                            )}
                        </figure>
                    ))}
                </div>
            ) : (
                <p class="empty">No images yet.</p>
            )
        }
    </main>

    </InnerPage>
</BaseLayout>

<script>

const overlay = document.getElementById('lightbox') as HTMLDivElement | null;
const lbImg   = document.getElementById('lightbox-img') as HTMLImageElement | null;
const lbCap   = document.getElementById('lightbox-caption') as HTMLElement | null;

if (overlay && lbImg && lbCap) {
  document.querySelectorAll<HTMLImageElement>('.image-grid figure img').forEach(img => {
    img.style.cursor = 'zoom-in';
    img.addEventListener('click', () => {
      lbImg.src = img.src;
      lbImg.alt = img.alt;
      const cap = img.closest('figure')?.querySelector('figcaption');
      lbCap.innerHTML = cap?.innerHTML ?? '';
      overlay.classList.add('active');
    });
  });

  overlay.addEventListener('click', (e: MouseEvent) => {
    if (e.target !== lbImg) overlay.classList.remove('active');
  });

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape') overlay.classList.remove('active');
  });
}

</script>


<style lang="scss">
    @use "../../styles/tokens" as *;

    .album-page {
        padding: $gap;
        /* max-width: 1200px; */
        /* margin: 0 auto; */
    }

    .image-grid {
        max-width: 1200px;
        margin: 0 auto;
        columns: 3;
        column-gap: $gap;

        @media (max-width: 768px) {
            columns: 2;
        }
    }
    figure {
        margin: 0 0 $gap 0;  // was margin: 0, need bottom gap now
        break-inside: avoid;
        img {
            width: 100%;
            height: auto;
            display: block;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.5);
        }
        figcaption {
            padding: 0.5rem 0;
            font-family: $font-body;
            font-size: 0.8rem;
            color: $color-muted;
            strong {
                color: $color-text;
            }
        }
    }
    .empty {
        color: $color-muted;
        font-family: $font-body;
    }

    .lightbox-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.85);
        z-index: 1000;
        cursor: zoom-out;
        align-items: center;
        justify-content: center;
        flex-direction: column;  // stack image + caption vertically
        gap: 1rem;
        padding: 2rem;

        &.active {
            display: flex;
        }

        img {
            max-width: 90vw;
            max-height: 80vh;  // reduced from 90vh to leave room for caption
            object-fit: contain;
            box-shadow: 0 8px 40px rgba(0, 0, 0, 0.8);
            cursor: default;
        }

        figcaption {
            // remove position: absolute, bottom, left, transform
            text-align: center;
            font-family: $font-body;
            font-size: 0.9rem;
            color: $color-muted;
            strong { color: $color-text; }
        }
    }
</style>
