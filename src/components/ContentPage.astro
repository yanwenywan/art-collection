---
import InnerPage from "./InnerPage.astro";

interface Props {
    title: string;
    backHref?: string;
    description?: string;
}
const { title, backHref = "/", description } = Astro.props;
---

<InnerPage title={title} description={description} backHref={backHref}>
    <div class="content-body">
        <slot />
    </div>
</InnerPage>

<style lang="scss">
    @use "../styles/tokens" as *;

    .content-body {
        max-width: 840px;
        width: 90%;
        margin: 0 auto;
        padding: $gap * 2 $gap * 2.5 $gap * 3;
        font-family: $font-body;
        color: $color-text;
        line-height: 1.7;
        background: $color-page;
        border-radius: 4px;

        @media screen and (max-width: 768px) {
            padding: $gap * 2 $gap $gap * 3;
        }
    }
</style>
