---
interface Props {
  src?: string;
  alt?: string;
  size?: number;
}
const { src, alt = 'Avatar', size = 96 } = Astro.props;
---

<div class="avatar-wrap" style={`width: ${size}px; height: ${size}px`}>
  {src
    ? <img src={src} {alt} class="avatar-img" />
    : <div class="avatar-placeholder" title="TODO: add avatar image" />
  }
</div>

<style lang="scss">
  @use '../styles/tokens' as *;

  .avatar-wrap {
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid rgba(255, 255, 255, 0.12);
    flex-shrink: 0;
  }

  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .avatar-placeholder {
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.06);
  }
</style>
