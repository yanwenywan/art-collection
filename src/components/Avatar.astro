---
interface Props {
  size?: number;
}
const { size = 96 } = Astro.props;
---

<img
  src="/images/seal.webp"
  alt="Yanwenyuan seal"
  width={size}
  height={size}
  class="seal"
/>

<style>
  .seal {
    display: block;
    object-fit: contain;
    filter: drop-shadow(0 3px 8px rgba(0, 0, 0, 0.9));
  }
</style>
