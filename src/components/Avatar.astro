---
import { Image } from 'astro:assets';
import sealImg from '../assets/images/seal.webp';

interface Props {
  size?: number;
}
const { size = 96 } = Astro.props;
---

<Image
  src={sealImg}
  alt="Yanwenyuan seal"
  width={size}
  height={size}
  quality={90}
  densities={[1, 2]}
  class="seal"
/>

<style>
  .seal {
    display: block;
    object-fit: contain;
    filter: drop-shadow(0 3px 8px rgba(0, 0, 0, 0.9));
  }
</style>
