---
import Avatar from './Avatar.astro';
---

<div class="sidebar">
  <Avatar size={96} />
  <div class="identity">
    <h2 class="name">燕文院<br/>Yanwenyuan</h2>
    <div class="social-row">
      <span class="social-link">
        <iconify-icon icon="simple-icons:discord" width="14" height="14" />
        <span>yanwenyuan</span>
      </span>
      <span class="sep">|</span>
      <a href="https://yanwenyuan.uk" class="social-link" target="_blank" rel="noopener noreferrer">
        <iconify-icon icon="ph:globe" width="14" height="14" />
        <span>website</span>
      </a>
    </div>
  </div>
  <hr/>
  <p class="bio">
    <!-- TODO: add real bio -->
    Digital art of mostly dragons. I also write in Classical Chinese and worldbuild sometimes.
  </p>
</div>

<style lang="scss">
  @use '../styles/tokens' as *;

  .sidebar {
    background: $color-surface;
    backdrop-filter: blur(8px);
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: $gap * 1.5 $gap;
    text-align: center;
  }

  .identity {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }

  .name {
    font-family: $font-display;
    font-weight: 700;
    font-size: 1.2rem;
    color: $color-text;
  }

  .social-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: $font-body;
    font-size: 0.8rem;
    color: $color-muted;
    text-decoration: none;
    transition: color 0.15s;

    &:hover {
      color: $color-text;
    }
  }

  .sep {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.2);
    user-select: none;
  }

  hr {
    width: 100%;
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .bio {
    font-family: $font-body;
    font-size: 0.85rem;
    color: $color-muted;
    line-height: 1.6;
  }

</style>
