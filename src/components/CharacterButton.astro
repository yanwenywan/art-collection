---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
    href: string;
    image: ImageMetadata | Promise<{ default: ImageMetadata }>;
    title: string;
    subtitle?: string;
    alt?: string;
}
const { href, image, title, subtitle, alt } = Astro.props;
---

<a href={href} class="char-btn">
    <span class="char-thumb">
        <Image src={image} alt={alt ?? title} />
    </span>
    <span class="char-text">
        <span class="char-title">{title}</span>
        {subtitle && <span class="char-sub">{subtitle}</span>}
    </span>
</a>

<style lang="scss">
    @use "../styles/tokens" as *;

    $btn-height: 80px;

    .char-btn {
        display: flex;
        height: $btn-height;
        background: $color-surface;
        border-radius: 4px;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
    }

    .char-thumb {
        flex: 0 0 $btn-height;
        width: $btn-height;
        height: $btn-height;
        overflow: hidden;

        :global(img) {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 0.3s ease;
        }
    }

    .char-btn:hover .char-thumb :global(img) {
        transform: scale(1.05);
    }

    .char-text {
        padding: 0.75rem 1rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.25rem;
    }

    .char-title {
        font-family: $font-display;
        font-weight: 600;
        color: $color-text;
    }

    .char-sub {
        font-family: $font-body;
        font-size: 0.8rem;
        color: $color-muted;
    }
</style>
